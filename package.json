{
  "name": "gltf-lab",
  "version": "1.0.8",
  "description": "Z-up GLTF model viewer",
  "author": "GLTF Lab contributors",
  "main": "desktop/main.cjs",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "desktop:dev": "vite --config desktop.vite.config.ts",
    "desktop:build": "vite build --config desktop.vite.config.ts",
    "desktop:package": "pnpm desktop:build && electron-builder --win nsis"
  },
  "dependencies": {
    "@types/three": "^0.185.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "electron": "39.2.7",
    "electron-builder": "24.13.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "build": {
    "appId": "jp.openai.gltflab",
    "productName": "GLTF Lab",
    "asar": true,
    "directories": {
      "output": "outputs/desktop"
    },
    "files": [
      "desktop-dist/**/*",
      "desktop/main.cjs",
      "desktop/preload.cjs",
      "package.json",
      "!node_modules/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "signAndEditExecutable": false,
      "artifactName": "GLTF-Lab-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
